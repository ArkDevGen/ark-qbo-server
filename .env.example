# ─────────────────────────────────────────────────────────────────
# ARK QBO Server — Environment Variables Template
#
# Copy this file to `.env` and fill in real values:
#   cp .env.example .env
#
# `.env` is gitignored — never commit real credentials.
# Production values live in Render's Environment tab.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=3000

# QuickBooks Online (intuit-oauth)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/qbo/callback
QBO_ENVIRONMENT=production
QBO_REALM_ID=

# Sinch — Fax (Basic auth)
SINCH_PROJECT_ID=
SINCH_FAX_KEY_ID=
SINCH_FAX_KEY_SECRET=
SINCH_FAX_NUMBER=

# Sinch — SMS (Bearer token)
SINCH_SMS_API_TOKEN=
SINCH_SMS_PLAN_ID=
SINCH_SMS_NUMBER=

# Anthropic (Claude API for dashboard AI features)
ANTHROPIC_API_KEY=

# Google (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Calendly (OAuth)
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
CALENDLY_REDIRECT_URI=

# ShareFile
SHAREFILE_CLIENT_ID=
SHAREFILE_CLIENT_SECRET=
SHAREFILE_USERNAME=
SHAREFILE_PASSWORD=
SHAREFILE_SUBDOMAIN=
SHAREFILE_REDIRECT_URI=

# Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_USER_ID=

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# Render API (for staging/deploy automation)
RENDER_API_KEY=
RENDER_EXTERNAL_URL=
RENDER_STAGING_SERVICE_ID=

# ARK internal API key (for protected endpoints)
ARK_API_KEY=

# Auto-seed admin (first-run bootstrap; leave empty in production)
AUTO_SEED_ADMIN=
AUTO_SEED_EMAIL=
AUTO_SEED_USERNAME=
AUTO_SEED_FNAME=
AUTO_SEED_LNAME=
AUTO_SEED_PASSWORD=
